@{
    ViewData["Title"] = "Home";
}

<section class="home-page">
    <div class="home-hero">
        <div class="home-copy">
            <span class="eyebrow">Masonry Estimator</span>
            <h1>Build cleaner project estimates with material and labor totals in one place.</h1>
            <p>Create masonry projects, add estimate items, review costs, and export material summaries from a secure workspace.</p>
            <div class="developer-credit">
                <span class="developer-avatar">SM</span>
                <span class="developer-copy">Developed by <strong>S M Asif Hossain</strong></span>
                <a class="linkedin-link" href="https://www.linkedin.com/in/smasifhossain/" target="_blank" rel="noreferrer" aria-label="S M Asif Hossain on LinkedIn">
                    <span aria-hidden="true">in</span>
                </a>
            </div>
        </div>
        <div class="home-preview-column">
            <div class="home-preview" aria-hidden="true">
                <div class="preview-bar"></div>
                <div class="preview-metric">
                    <span>Materials</span>
                    <strong data-demo-amount="materials">$18,420</strong>
                </div>
                <div class="preview-metric">
                    <span>Labor</span>
                    <strong data-demo-amount="labor">$26,800</strong>
                </div>
                <div class="preview-metric">
                    <span>Total</span>
                    <strong data-demo-amount="total">$45,220</strong>
                </div>
                <div class="preview-table">
                    <span>CMU wall</span>
                    <b data-demo-amount="cmu">$12,300</b>
                    <span>Brick veneer</span>
                    <b data-demo-amount="brick">$22,480</b>
                    <span>Mortar</span>
                    <b data-demo-amount="mortar">$1,960</b>
                </div>
            </div>
        </div>
    </div>
</section>
