@model MasonryEstimation.Models.RegisterViewModel

@{
    ViewData["Title"] = "Create account";
}

<section class="auth-page">
    <div class="auth-panel">
        <div class="auth-heading">
            <span class="auth-kicker">New workspace</span>
            <h1>Create account</h1>
            <p>Start a workspace for your masonry projects.</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="new-password" />
            <span asp-validation-for="Password"></span>

            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword"></span>

            <button type="submit" class="btn-app">Create account</button>
        </form>

        <p class="auth-switch">Already have an account? <a asp-action="Login">Sign in</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
